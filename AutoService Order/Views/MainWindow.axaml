<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AutoService_Order.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AutoService_Order.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="AutoService_Order">
    <Grid RowDefinitions="* Auto Auto Auto Auto *"
          ColumnDefinitions="* Auto *">
        <TextBox Width="200" Grid.Row="1" Grid.Column="1" Watermark="Client Name" Text="{Binding ClientName}"/>
        <TextBox Grid.Row="2" Grid.Column="1"  Watermark="Auto" Text="{Binding AutoName}"/>
        <ComboBox Grid.Row="3" Grid.Column="1" PlaceholderText="Service"
                  ItemsSource="{Binding Services}"
                  SelectedItem="{Binding SelectedService}"
                  DisplayMemberBinding="{Binding Title}"
                  Width="200">
        </ComboBox>
        <Button HorizontalAlignment="Right" Grid.Row="4" Grid.Column="1"  Content="Start Work" Command="{Binding StartService}"/>
        
    </Grid>
</Window>
